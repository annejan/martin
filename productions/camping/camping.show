# martin — the "OP DE CAMPING" demo. The full-fat local demo (uses the big gitignored captures);
# the CI/bundle showcase is its own production (productions/intro/). Synced to the Op de Camping
# track (140 BPM, ~228s). The 6 scenes follow the SHOWBOOK arc: deFEEST drijft in → het dorp bouwt
# op → het feest barst los → zonder deFEEST is het kut → met deFEEST = het ultieme genot → greetings.
#
#   MARTIN_SHOW=productions/camping/camping.show cargo +nightly run --release
#   MARTIN_SHOW=productions/camping/camping.show ./record.sh op-de-camping.mp4
#
# STAND-IN STATUS: scenes 2/3/5 want REAL camping captures (tent / krat / club-mate / BBQ / food
# table / cheering deFEEST members — see the SHOWBOOK capture list). Until those are shot, the lines
# marked `# STAND-IN` use existing local clouds (Ægg / dog / Martin / galaxy / bitterbal) as
# placeholders so the whole 228s show plays end-to-end. Swap the real captures in when they land.

# --- settings (each → MARTIN_<KEY>) ---
budget       = 160000
ply = assets/aegg-baked.ply          # .ply root = assets/ so `splat:` filenames resolve
score = productions/camping/score.txt # the Op de Camping arrangement (this production owns it)
bg_dim = 0.35
flash = 0.45                          # bloom flash on the @@anchored cuts
beat = 0.3                            # subtle beat-reaction (no thump/bounce on every kick)
pw_splat = 0.004                      # crisp pen-write strokes

# --- the show. BACKBONE = the sexy ball-pulse ~morph (disperse-to-ball → reassemble; bulge = 3rd @).
#     Deforms rotational/lively (twist/turbulence/wind/wave), not bob. glb: dissolve carries no deform. ---
[reel]
# ==== 1 · INTRO (0–14) · deFEEST mesh floats in, dissolves to blobs, then BURSTS ====
glb:defeest.glb               @@intro    @11,3                  exit:explode  backdrop:off     # deFEEST mesh ⇄ splats → explode
# ==== 2 · BUILD (14–43) · BornHack (host camp) reveals + bursts, then the deFEEST village builds ====
glb:bornhack.glb              @@build    @5,2                   exit:explode  backdrop:stars   # HOST camp: mesh ⇄ splats → explode
splat:aegg.ply                           @5,2,1.2 ~morph       ^twist        backdrop:stars   # STAND-IN prop (real: tent/krat)
mesh:bitterbal.glb flock:5   @5,2      ~morph     ^wind                    backdrop:grid    # STAND-IN food/BBQ
text:OP DE CAMPING             @7,2      ~typewriter ^wave                   backdrop:grid    # the title lands
# ==== 3 · DROP (43–99) · the party bursts: splats waving, rainbow bg, food + cheering crew ====
splat:doggo.ply               @@drop     @8,1.4,1.5 ~morph     ^wave         backdrop:plasma  # STAND-IN cheering crew (real: members)
splat:supershape.ply          @@bar:34   @8,1.4,1.5 ~morph     ^wave         backdrop:kaleido # rainbow party morph
text:MET deFEEST              @@bar:43    @7,1.4    ~explode    ^wave         backdrop:plasma  # the hook
mesh:bitterbal.glb flock:7  @@bar:51    @8,1.6    ~morph     ^wind  exit:evaporate backdrop:kaleido # bitterballen
# ==== 4 · BREAKDOWN (99–129) · night, starfield, sad: zonder deFEEST is het kut ====
text:ZONDER deFEEST          @@breakdown  @12,3     ~morph      ^ripple       backdrop:stars   # the tragic turn (night)
text:IS HET KUT               @12,3      ~fade      ^wave                    backdrop:stars   # …is kut
# ==== 5 · CLIMAX (129–185) · peak party: crew, rainbows, ball-pulse bursts, bitterballen rain ====
splat:martin-peace.ply        @@climax   @9,1.4,1.6 ~morph     ^wave         backdrop:plasma  # STAND-IN crew (real: cheering members)
text:MET deFEEST             @@bar:84     @7,1.5    ~explode    ^wave         backdrop:kaleido # the ultimate joy
splat:galaxy.ply             @@bar:93     @8,1.4,1.4 ~morph    ^turbulence    backdrop:plasma  # euphoria spins out
mesh:bitterbal.glb flock:9 @@bar:101    @8,1.6    ~morph     ^wind          backdrop:kaleido # bitterballen rain
# ==== 6 · OUTRO (185–228) · greetings + credits ====
wall:GREETINGS|TO ALL|SCENE & CAMP @@outro @6,2.5   ~morph      ^wave         backdrop:stars   # PLACEHOLDER greet — fill real group names
svg:bornhack.svg               @5,2      ~morph     ^wave                    backdrop:stars   # …esp. our hosts: BornHack
wall:ANUS|KLOOT|CINDER         @6,2.5    ~morph     ^wave                    backdrop:stars   # the crew
text:deFEEST                   @7,3      ~pen-write ^wave                    backdrop:stars   # signature
text:a deFEEST production      @5,2.5    ~fade      ^wave  exit:evaporate     backdrop:off      # …fades to black

# --- camera: FRONT-FACING (yaw ~1.1–1.7, text/credits read head-on); per-scene regime — float-in
#     (intro), push (build), energetic push-ins (drop), sink/drift (breakdown), in-tight (climax),
#     pull-back (outro). No back-of-subject orbit. ---
[camera]
t=0.0     pos=0,0,0   dist=3.0   yaw=1.45   pitch=0.10   # intro: deFEEST mesh floats in
t=11.0    pos=0,0,0   dist=2.6   yaw=1.38   pitch=0.14   # settle as it dissolves to blobs
t=14.0    pos=0,0,0   dist=2.7   yaw=1.55   pitch=0.16   # build: orbit-ish drift as the camp builds
t=30.0    pos=0,0,0   dist=2.5   yaw=1.25   pitch=0.18   # slow push toward the title
t=43.0    pos=0,0,0   dist=1.95  yaw=1.45   pitch=0.20   # DROP: push in hard, head-on
t=60.0    pos=0.3,0,0 dist=2.2   yaw=1.62   pitch=0.18   # arc right across the party (frontal)
t=80.0    pos=-0.3,0,0 dist=2.2  yaw=1.28   pitch=0.18   # counter-arc left, ride the hook
t=99.0    pos=0,0,0   dist=3.1   yaw=1.40   pitch=0.08   # breakdown: fall back, sink for the sad turn
t=120.0   pos=0,0,0   dist=3.2   yaw=1.45   pitch=0.06   # drift, lowest energy
t=129.0   pos=0,0,0   dist=1.9   yaw=1.50   pitch=0.20   # CLIMAX: slam in
t=150.0   pos=0.3,0.1,0 dist=2.1 yaw=1.64   pitch=0.22   # arc through the peak (frontal)
t=170.0   pos=-0.3,0,0 dist=2.1  yaw=1.26   pitch=0.20   # counter-arc, ride the high
t=185.0   pos=0,0,0   dist=3.0   yaw=1.42   pitch=0.06   # outro: pull back + level for the greetings/credits
t=210.0   pos=0,0,0   dist=3.1   yaw=1.45   pitch=0.05   # hold frontal for the credits
t=227.0   pos=0,0,0   dist=3.5   yaw=1.45   pitch=0.05   # gentle pull-back, evaporate to black
